@startuml

hide footbox

participant Detector
participant MainWindow
participant SHM
participant "LegacyJtDecodeWorker.cpp" as LegacyWorker
participant "legacy_jt_async_decode.f90" as AsyncJT
participant "jt9_decode.f90" as JT9Decode

Detector -> MainWindow : dataSink()

activate MainWindow
MainWindow -> MainWindow : decode()
MainWindow -> MainWindow : decodeBusy()

MainWindow -> SHM : memcpy()
MainWindow -> LegacyWorker : queued decode(request)
deactivate MainWindow

activate LegacyWorker
LegacyWorker -> AsyncJT : legacy_jt_async_decode()

activate AsyncJT
AsyncJT -> JT9Decode : jt9_decoder%decode()
JT9Decode -> AsyncJT : decoded lines
AsyncJT -> LegacyWorker : collected rows
deactivate AsyncJT

LegacyWorker -> MainWindow : decodeReady()
deactivate LegacyWorker

@enduml
