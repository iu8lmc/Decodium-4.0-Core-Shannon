<?xml version="1.0" encoding="utf-8" ?>
<!-- SignPath artifact configuration for Decodium 4.0 Core Shannon (Qt6 QML) -->
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <zip-file>
    <!-- Main application executable -->
    <pe-file path="decodium.exe">
      <authenticode-sign hash-algorithm="sha256"
                         description="Decodium 4.0 Core Shannon - Digital Modes for Amateur Radio"
                         description-url="https://github.com/iu8lmc/Decodium-4.0-Core-Shannon" />
    </pe-file>

    <!-- Third-party DLLs: do not sign (MinGW runtime, Qt6, etc.) -->
    <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />

    <!-- Qt6 plugin directories -->
    <directory path="platforms" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="audio" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="imageformats" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="sqldrivers" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="styles" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="multimedia" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="tls" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>
    <directory path="networkinformation" min-matches="0">
      <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
    </directory>

    <!-- QML directories (Qt6 QML modules + app QML) -->
    <directory path="qml" min-matches="0">
      <deep-directory min-matches="0">
        <pe-file path="*.dll" max-matches="unbounded" min-matches="0" />
      </deep-directory>
    </directory>
  </zip-file>
</artifact-configuration>
